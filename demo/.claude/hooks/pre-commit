#!/usr/bin/env bash
# .claude/hooks/pre-commit
#
# Runs automatically before every git commit.
# Validates the three rules JSON files and the agent registry.
#
# Install:  ln -s ../../.claude/hooks/pre-commit .git/hooks/pre-commit
# Bypass:   git commit --no-verify   (don't — fix the validator instead)

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'   # no color

echo -e "${YELLOW}▶ sprinkler-tools pre-commit checks${NC}"

# ─────────────────────────────────────────────────────────────
# 1. JSON well-formedness for all three rule files
# ─────────────────────────────────────────────────────────────
echo "  1/4  Validating rule JSON files..."

for file in backend/rules/nfpa13_rules.json \
            backend/rules/california_amendments.json \
            backend/rules/lamc_amendments.json; do
    if [ ! -f "$file" ]; then
        echo -e "${RED}  ✗ Missing rule file: $file${NC}"
        exit 1
    fi
    if ! python3 -c "import json; json.load(open('$file'))" 2>/dev/null; then
        echo -e "${RED}  ✗ Invalid JSON: $file${NC}"
        python3 -c "import json; json.load(open('$file'))"
        exit 1
    fi
done

# ─────────────────────────────────────────────────────────────
# 2. Schema validation (rule_id uniqueness, required fields,
#    ai_impact taxonomy)
# ─────────────────────────────────────────────────────────────
echo "  2/4  Running rule schema validator..."

python3 <<'PY'
import json
import sys
from pathlib import Path

ALLOWED_AI_IMPACT = {"placement", "validator", "both"}
ALLOWED_SOURCES   = {"NFPA13", "California", "LAMC"}
REQUIRED_FIELDS   = {"rule_id", "source", "section", "rule_type",
                     "ai_impact", "condition", "requirement", "human_summary"}

files = [
    "backend/rules/nfpa13_rules.json",
    "backend/rules/california_amendments.json",
    "backend/rules/lamc_amendments.json",
]

errors = []
seen_ids = {}

for path in files:
    data = json.loads(Path(path).read_text())
    rules = data.get("rules", [])
    for r in rules:
        rid = r.get("rule_id", "<missing>")

        # uniqueness across all three files
        if rid in seen_ids:
            errors.append(f"{path}: duplicate rule_id '{rid}' (also in {seen_ids[rid]})")
        seen_ids[rid] = path

        # required fields
        missing = REQUIRED_FIELDS - set(r.keys())
        if missing:
            errors.append(f"{path}:{rid}: missing fields {sorted(missing)}")

        # ai_impact taxonomy
        if r.get("ai_impact") not in ALLOWED_AI_IMPACT:
            errors.append(
                f"{path}:{rid}: ai_impact='{r.get('ai_impact')}' "
                f"not in {sorted(ALLOWED_AI_IMPACT)}"
            )

        # source taxonomy
        if r.get("source") not in ALLOWED_SOURCES:
            errors.append(
                f"{path}:{rid}: source='{r.get('source')}' "
                f"not in {sorted(ALLOWED_SOURCES)}"
            )

if errors:
    print("\n".join("    " + e for e in errors))
    sys.exit(1)

print(f"    ✓ {len(seen_ids)} rules validated, all unique")
PY

# ─────────────────────────────────────────────────────────────
# 3. Agent registry — every agent_id 1..50 must be registered
# ─────────────────────────────────────────────────────────────
echo "  3/4  Checking agent registry..."

if [ -f "backend/agents/__init__.py" ]; then
    python3 <<'PY'
import sys, importlib.util, pathlib
spec = importlib.util.spec_from_file_location(
    "agents_init", "backend/agents/__init__.py"
)
mod = importlib.util.module_from_spec(spec)
try:
    spec.loader.exec_module(mod)
except Exception as e:
    print(f"    ✗ Could not import agents/__init__.py: {e}")
    sys.exit(0)  # don't block commit if optional deps missing locally

agents = getattr(mod, "ALL_AGENTS", [])
ids = [a.agent_id for a in agents]
expected = set(range(1, 51))
got = set(ids)
missing = expected - got
extra   = got - expected
duplicates = [i for i in ids if ids.count(i) > 1]

if missing:
    print(f"    ✗ Missing agent IDs: {sorted(missing)}")
    sys.exit(1)
if extra:
    print(f"    ✗ Unexpected agent IDs > 50: {sorted(extra)}")
    sys.exit(1)
if duplicates:
    print(f"    ✗ Duplicate agent IDs: {sorted(set(duplicates))}")
    sys.exit(1)
print(f"    ✓ All 50 agents registered")
PY
fi

# ─────────────────────────────────────────────────────────────
# 4. Forbidden patterns — catch common mistakes
# ─────────────────────────────────────────────────────────────
echo "  4/4  Scanning for forbidden patterns..."

# print() in backend code
if git diff --cached --name-only | grep -E '^backend/.*\.py$' | xargs -r grep -l '^[^#]*print(' 2>/dev/null; then
    echo -e "${RED}    ✗ print() found in backend code — use logging.getLogger(__name__)${NC}"
    exit 1
fi

# committing model weights (too big for git)
if git diff --cached --name-only | grep -E '\.(pt|pth|onnx|bin|safetensors)$' >/dev/null; then
    echo -e "${RED}    ✗ Model weight files should not be committed (use Git LFS or external storage)${NC}"
    exit 1
fi

echo "    ✓ No forbidden patterns"
echo -e "${GREEN}✓ All pre-commit checks passed${NC}"
